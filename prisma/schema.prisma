generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  CPU
  GPU
  MOTHERBOARD
  RAM
  SSD
  HDD
  PSU
  CASE
  COOLER
  MONITOR
  KEYBOARD
  MOUSE
  HEADSET
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  favorites Favorite[]
  alerts    Alert[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Retailer {
  id      String @id @default(cuid())
  name    String @unique
  slug    String @unique
  website String
  logo    String?
  active  Boolean @default(true)

  prices Price[]

  @@map("retailers")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  brand       String
  model       String
  category    Category
  description String?  @db.Text
  image       String?
  specs       Json?
  asin        String?
  sku         String?
  active      Boolean  @default(true)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prices       Price[]
  priceHistory PriceHistory[]
  favorites    Favorite[]
  alerts       Alert[]

  @@index([category])
  @@index([brand])
  @@index([slug])
  @@map("products")
}

model Price {
  id           String   @id @default(cuid())
  productId    String
  retailerId   String
  price        Float
  originalPrice Float?
  currency     String   @default("USD")
  url          String
  inStock      Boolean  @default(true)
  shipping     Float?
  lastChecked  DateTime @default(now())
  createdAt    DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  retailer Retailer @relation(fields: [retailerId], references: [id])

  @@unique([productId, retailerId])
  @@index([productId])
  @@map("prices")
}

model PriceHistory {
  id         String   @id @default(cuid())
  productId  String
  retailerId String
  price      Float
  inStock    Boolean  @default(true)
  recordedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([recordedAt])
  @@map("price_history")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favorites")
}

model Alert {
  id          String    @id @default(cuid())
  userId      String
  productId   String
  targetPrice Float
  active      Boolean   @default(true)
  triggered   Boolean   @default(false)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("alerts")
}

model FetchLog {
  id        String   @id @default(cuid())
  retailer  String
  product   String?
  status    String
  error     String?  @db.Text
  duration  Int?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("fetch_logs")
}
