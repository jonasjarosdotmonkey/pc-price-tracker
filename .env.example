# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/pc_price_tracker"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Email (Nodemailer)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="your@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="PC Price Tracker <noreply@pcpricetracker.com>"

# Cron secret (used to protect /api/cron routes)
CRON_SECRET="your-cron-secret"

# Optional: Price provider API keys
# AMAZON_PRODUCT_API_KEY=""
# AMAZON_PRODUCT_API_SECRET=""
# AMAZON_ASSOCIATE_TAG=""
